# F1 SignalR live timing
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Preferisci F1_SIGNALR_LOGIN_SESSION: incolla il valore URL-encoded del cookie
# login-session. In alternativa usa solo il subscriptionToken in
# F1_SIGNALR_AUTH_TOKEN. Non esiste necessariamente un cookie chiamato
# "auth token": qui "auth token" significa il JWT subscriptionToken contenuto
# dentro login-session.
# Verifica il contenuto con: python -m app.token_tool
F1_SIGNALR_LOGIN_SESSION=
F1_SIGNALR_AUTH_TOKEN=
F1_SIGNALR_TIMEOUT_SECONDS=90

# Archivio locale dei live snapshot in JSONL, utile per replay e prediction.
# Il percorso e' relativo alla cartella backend quando usi backend/run-dev.sh.
F1_SIGNALR_ARCHIVE_ENABLED=true
F1_SIGNALR_ARCHIVE_DIR=.cache/f1signal
F1_SIGNALR_SNAPSHOT_ARCHIVE_INTERVAL_SECONDS=5

# Endpoint F1 live timing. Cambiali solo se il feed F1 cambia URL.
F1_SIGNALR_CONNECTION_URL=wss://livetiming.formula1.com/signalrcore
F1_SIGNALR_NEGOTIATE_URL=https://livetiming.formula1.com/signalrcore/negotiate

# Integrazione OpenF1 storica opzionale, disattivata di default.
ENABLE_OPENF1_HISTORY=false

# Trascrizione opzionale team radio. "local" usa faster-whisper sulla macchina.
# Traduzione IT: googletrans e' gratuito ma usa il servizio Google non ufficiale.
# Alternative: openai, none.
TEAM_RADIO_TRANSCRIPTION_PROVIDER=local
TEAM_RADIO_LOCAL_WHISPER_MODEL=base
TEAM_RADIO_LOCAL_WHISPER_DEVICE=auto
TEAM_RADIO_LOCAL_WHISPER_COMPUTE_TYPE=float32
TEAM_RADIO_AUTO_TRANSCRIPTION_ENABLED=true
TEAM_RADIO_AUTO_TRANSCRIPTION_CONCURRENCY=1
TEAM_RADIO_AUTO_TRANSLATE_ENABLED=false
TEAM_RADIO_TRANSCRIPTION_CACHE_ENABLED=true
TEAM_RADIO_TRANSLATION_PROVIDER=googletrans
OPENAI_API_KEY=
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-transcribe
OPENAI_TRANSLATION_MODEL=gpt-5.2

# Prediction Center: pacchetti upgrade dichiarati per gara/team.
# Il file e' opzionale e puo' essere compilato a mano da report FIA/team.
PREDICTION_UPGRADES_FILE=.cache/predictions/team_upgrades.json
